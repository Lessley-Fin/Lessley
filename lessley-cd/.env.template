# ===========================
# MongoDB Configuration
# ===========================
DB_USER=guest
DB_PASS=your_secure_mongodb_password_here
DB_NAME=lessley

# ===========================
# RabbitMQ Configuration
# ===========================
RABBIT_USER=guest
RABBIT_PASS=your_secure_rabbitmq_password_here

# ===========================
# JWT Configuration
# ===========================
JWT_KEY=your_jwt_secret_key_min_32_characters_long
JWT_ISSUER=lessley-app
JWT_AUDIENCE=lessley-users

# ===========================
# Open Finance Configuration
# ===========================
OpenFinanceConfig_ClientId=lessley-openfinance-client-id
OpenFinanceConfig_ClientSecret=lessley-openfinance-client-secret

# ===========================
# Bootstrap Configuration
# ===========================
BOOTSTRAP_KEY=bootstrap-secret-key
BOOTSTRAP_USER=admin@lessley1!
BOOTSTRAP_PASSWORD=initial_admin_password
BOOTSTRAP_EMAIL=admin@lessley.local

# ===========================
# Scraper (Python Hot)
# ===========================
HOT_SCRAPER_PAGE_START=1
HOT_SCRAPER_MAX_PAGES=30
HOT_SCRAPER_REQUEST_DELAY=0.7
HOT_SCRAPER_INTERVAL_SECONDS=604800
HOT_IMPORT_SOURCE=api #file or api 
HOT_API_PAGE_START=1
HOT_API_MAX_PAGES=1000
HOT_API_REQUEST_DELAY=1.0
HOT_OUTPUT_FILE=hot/outputs/hot_getAllBenefits.json
SCRAPER_OFFERS_COLLECTION=benefits
SCRAPER_CARDS_COLLECTION=cards
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Behatsdaa scraper runtime
BEHATSDAA_IMPORT_SOURCE=api #file or api
BEHATSDAA_API_REQUEST_DELAY=1.0
BEHATSDAA_SCRAPER_INTERVAL_SECONDS=604800
BEHATSDAA_KEEPALIVE_ENABLED=true
BEHATSDAA_KEEPALIVE_SECONDS=300
BEHATSDAA_KEEPALIVE_ENDPOINT=/api/category/GetCategoryHeader
BEHATSDAA_INPUT_FILE=outputs/behatsdaa_wallets.json
BEHATSDAA_CARDS_OUTPUT=outputs/behatsdaa_cards.json

# Behatsdaa API headers/session
BEHATSDAA_ACCESS_TOKEN=
BEHATSDAA_COOKIE=
BEHATSDAA_ORGANIZATION_ID=20
BEHATSDAA_NATIVE=true
BEHATSDAA_ORIGIN=https://www.behatsdaa.org.il
BEHATSDAA_REFERER=https://www.behatsdaa.org.il/

