# .env
ENVIRONMENT="Development"

# ===========================
# RabbitMQ Configuration
# ===========================
ConnectionStrings_Rabbit="amqp://YOUR_USERNAME:YOUR_PASSWORD@localhost/"

# ===========================
# Open Finance Configuration
# ===========================
OpenFinanceConfig_ClientId=your_open_finance_client_id_here
OpenFinanceConfig_ClientSecret=your_open_finance_client_secret_here
