# Runtime
SCRAPER_PAGE_START=1
SCRAPER_MAX_PAGES=10
SCRAPER_REQUEST_DELAY=0.7

# Mongo
# Use the project's shared MongoDB service
MONGO_URI=mongodb://guest:guest@localhost:27017/lessley?authSource=admin
MONGO_DATABASE=lessley
MONGO_OFFERS_COLLECTION=benefits
MONGO_CARDS_COLLECTION=cards

# Optional LLM normalization (fallback is used if key is empty)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Behatsdaa scraper runtime
BEHATSDAA_IMPORT_SOURCE=api
BEHATSDAA_API_REQUEST_DELAY=1.0
BEHATSDAA_SCRAPER_INTERVAL_SECONDS=604800
BEHATSDAA_KEEPALIVE_ENABLED=true
BEHATSDAA_KEEPALIVE_SECONDS=300
BEHATSDAA_KEEPALIVE_ENDPOINT=/api/category/GetCategoryHeader
BEHATSDAA_INPUT_FILE=outputs/behatsdaa_wallets.json
BEHATSDAA_CARDS_OUTPUT=outputs/behatsdaa_cards.json

# Behatsdaa API headers/session
BEHATSDAA_ACCESS_TOKEN=
BEHATSDAA_COOKIE=
BEHATSDAA_ORGANIZATION_ID=20
BEHATSDAA_NATIVE=true
BEHATSDAA_ORIGIN=https://www.behatsdaa.org.il
BEHATSDAA_REFERER=https://www.behatsdaa.org.il/
